{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Say To Any",
  "version": "0.1.0",
  "identifier": "com.saytoany.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:6013",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist/client"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Say To Any",
        "width": 1080,
        "height": 744,
        "minWidth": 980,
        "minHeight": 680,
        "decorations": false,
        "shadow": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
