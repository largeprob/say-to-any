{
  "name": "say-to-any-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "build:ssg": "react-router build",
    "dev": "react-router dev --port 6002",
    "preview:ssg": "vite preview --host 0.0.0.0 --port 6002 --outDir build/client",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc"
  },
  "dependencies": {
    "@react-router/node": "7.15.0",
    "@react-router/serve": "7.15.0",
    "isbot": "^5.1.36",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "7.15.0"
  },
  "devDependencies": {
    "@react-router/dev": "7.15.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.3"
  }
}
