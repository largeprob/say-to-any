<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:pc.ViewModels"
        x:Class="pc.Views.PasteFallbackOverlayWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="460"
        Height="190"
        CanResize="False"
        ShowActivated="False"
        ShowInTaskbar="False"
        WindowDecorations="None"
        Topmost="True"
        Background="Transparent"
        TransparencyLevelHint="Transparent">

    <Window.Styles>
        <Style Selector="Button.copy-button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Background" Value="#126DFF"/>
            <Setter Property="BorderBrush" Value="#126DFF"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style Selector="Button.copy-button:pointerover">
            <Setter Property="Background" Value="#0F3F89"/>
            <Setter Property="BorderBrush" Value="#0F3F89"/>
        </Style>

        <Style Selector="Button.copy-button:pointerover /template/ Border#RootBorder">
            <Setter Property="Background" Value="#0F3F89"/>
            <Setter Property="BorderBrush" Value="#0F3F89"/>
        </Style>

        <Style Selector="Button.close-button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Styles>

    <Border Margin="10"
            Padding="16"
            CornerRadius="22"
            Background="#E6000000"
            BoxShadow="0 8 28 0 #66000000">
        <Grid RowDefinitions="Auto,*,Auto">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="已复制到剪贴板"
                           Foreground="#FFFFFF"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Classes="close-button"
                        Content="×"
                        Command="{Binding DismissPasteFallbackCommand}"
                        ToolTip.Tip="关闭"/>
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,10,0,12"
                    Padding="10"
                    CornerRadius="12"
                    Background="#33111827">
                <TextBlock Text="{Binding PasteFallbackText}"
                           Foreground="#FFFFFF"
                           TextWrapping="Wrap"
                           MaxHeight="74"/>
            </Border>

            <Button Grid.Row="2"
                    Classes="copy-button"
                    Content="复制"
                    Command="{Binding CopyPasteFallbackTextCommand}"
                    HorizontalAlignment="Right"/>
        </Grid>
    </Border>
</Window>
