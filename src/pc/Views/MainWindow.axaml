<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:pc.ViewModels"
        xmlns:models="using:pc.Models"
        xmlns:suki="https://github.com/kikipoulet/SukiUI"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1080"
        d:DesignHeight="744"
        Width="1080"
        Height="744"
        MinWidth="980"
        MinHeight="680"
        x:Class="pc.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/SayToAny_Logo.ico"
        Title=""
        WindowStartupLocation="CenterScreen"
        Background="#F8F9FB">

    <Grid Background="#F8F9FB">
        <Grid.Styles>
            <Style Selector="Grid.modal-open">
                <Setter Property="Effect" Value="blur(8)"/>
            </Style>

            <Style Selector="ToolTip">
                <Setter Property="Background" Value="#111827"/>
                <Setter Property="Foreground" Value="#FFFFFF"/>
                <Setter Property="Padding" Value="8,5"/>
            </Style>

            <Style Selector="Button.main-nav-button:pointerover">
                <Setter Property="Background" Value="#EAF3FF"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
            </Style>

            <Style Selector="Button.main-nav-button:pointerover /template/ Border#RootBorder">
                <Setter Property="Background" Value="#EAF3FF"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
            </Style>

            <Style Selector="TextBox.home-transcript-input">
                <Setter Property="Background" Value="#FFFFFF"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground" Value="#102A56"/>
            </Style>

            <Style Selector="Button.home-copy-button">
                <Setter Property="Background" Value="#FFFFFF"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground" Value="#126DFF"/>
            </Style>

            <Style Selector="Button.home-copy-button:pointerover">
                <Setter Property="Background" Value="#EAF3FF"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="Foreground" Value="#0F3F89"/>
            </Style>

            <Style Selector="Button.home-copy-button:pointerover /template/ Border#RootBorder">
                <Setter Property="Background" Value="#EAF3FF"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
            </Style>

            <Style Selector="Border.history-record">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="CornerRadius" Value="8"/>
            </Style>

            <Style Selector="Border.history-record:pointerover">
                <Setter Property="Background" Value="#EEF5FF"/>
            </Style>

            <Style Selector="StackPanel.history-actions">
                <Setter Property="Opacity" Value="0"/>
                <Setter Property="IsHitTestVisible" Value="False"/>
            </Style>

            <Style Selector="Border.history-record:pointerover StackPanel.history-actions">
                <Setter Property="Opacity" Value="1"/>
                <Setter Property="IsHitTestVisible" Value="True"/>
            </Style>

            <Style Selector="Border.history-record.actions-open StackPanel.history-actions">
                <Setter Property="Opacity" Value="1"/>
                <Setter Property="IsHitTestVisible" Value="True"/>
            </Style>

            <Style Selector="Button.history-action-button">
                <Setter Property="Background" Value="#F5F9FF"/>
                <Setter Property="Foreground" Value="#526681"/>
                <Setter Property="BorderThickness" Value="0"/>
            </Style>

            <Style Selector="Button.history-action-button:pointerover">
                <Setter Property="Background" Value="#DDEBFF"/>
                <Setter Property="Foreground" Value="#0F3F89"/>
            </Style>

            <Style Selector="Button.history-action-button.menu-open">
                <Setter Property="Background" Value="#DDEBFF"/>
                <Setter Property="Foreground" Value="#0F3F89"/>
            </Style>

            <Style Selector="Button.history-menu-button">
                <Setter Property="Width" Value="42"/>
            </Style>

            <Style Selector="ContextMenu.history-more-menu">
                <Setter Property="MinWidth" Value="156"/>
                <Setter Property="Background" Value="#FFFFFF"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="CornerRadius" Value="12"/>
            </Style>

            <Style Selector="ContextMenu.history-more-menu /template/ ItemsPresenter#PART_ItemsPresenter">
                <Setter Property="Margin" Value="6"/>
            </Style>

            <Style Selector="ContextMenu.history-more-menu MenuItem">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Margin" Value="0,1"/>
                <Setter Property="MinHeight" Value="36"/>
                <Setter Property="Padding" Value="10,7"/>
            </Style>

            <Style Selector="ContextMenu.history-more-menu MenuItem /template/ Border#root">
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="CornerRadius" Value="8"/>
            </Style>

            <Style Selector="ContextMenu.history-more-menu MenuItem /template/ Rectangle#PART_HorizontalSeparator">
                <Setter Property="Width" Value="0"/>
                <Setter Property="Margin" Value="8,0,0,0"/>
                <Setter Property="Fill" Value="Transparent"/>
            </Style>

            <Style Selector="ContextMenu.history-more-menu MenuItem:pointerover">
                <Setter Property="Background" Value="#EEF5FF"/>
            </Style>

            <Style Selector="ContextMenu.history-more-menu MenuItem.danger-menu-item:pointerover">
                <Setter Property="Background" Value="#FEF2F2"/>
            </Style>
        </Grid.Styles>

 
        <Grid x:Name="AppShell"
              ColumnDefinitions="202,*"
              Background="#F8F9FB">
        <Border Background="#F8F9FB"
                BorderThickness="0">
            <Grid RowDefinitions="Auto,*,Auto" Margin="10,22,10,14">
                <StackPanel>
                    <Grid ColumnDefinitions="*,Auto" Margin="8,0,4,18">
                        <TextBlock Text="Q  Say To Any"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#0E2246"
                                   VerticalAlignment="Center"/>
                        <Border Grid.Column="1"
                                Background="#E9F2FF"
                                CornerRadius="14"
                                Padding="12,4"
                                VerticalAlignment="Center">
                            <TextBlock Text="Free"
                                       FontSize="12"
                                       Foreground="#126DFF"/>
                        </Border>
                    </Grid>

                    <StackPanel Spacing="6">
                        <Grid Height="36">
                            <Border Background="#EAF3FF"
                                    CornerRadius="12"
                                    IsVisible="{Binding IsHomeVisible}"/>
                            <Button Classes="Flat Rounded main-nav-button"
                                    Content="⌂  首页"
                                    Command="{Binding ShowHomeCommand}"
                                    HorizontalContentAlignment="Left"
                                    Padding="11,0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="{Binding HomeNavigationForeground}"/>
                        </Grid>

                        <Grid Height="36">
                            <Border Background="#EAF3FF"
                                    CornerRadius="12"
                                    IsVisible="{Binding IsHistoryVisible}"/>
                            <Button Classes="Flat Rounded main-nav-button"
                                    Content="◷  历史记录"
                                    Command="{Binding ShowHistoryCommand}"
                                    HorizontalContentAlignment="Left"
                                    Padding="11,0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="{Binding HistoryNavigationForeground}"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="2" Spacing="12">
                   
                    <Border Background="#FFFFFF"
                            BorderBrush="#E6EEFA"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="本地听写"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#0E2246"/>
                            <TextBlock Text="{Binding WordUsageText}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#0E2246"/>
                            <Border Height="4"
                                    Background="#E5EDF8"
                                    CornerRadius="2">
                                <Border Width="36"
                                        HorizontalAlignment="Left"
                                        Background="#126DFF"
                                        CornerRadius="2"/>
                            </Border>
                            <TextBlock Text="双击 Alt 即可开始或停止录音"
                                       TextWrapping="Wrap"
                                       FontSize="12"
                                       Foreground="#6F7F99"/>
                            <Grid Height="40">
                                <Button Content="开始听写"
                                        Command="{Binding ToggleDictationCommand}"
                                        IsVisible="{Binding IsNotRecording}"
                                        IsEnabled="{Binding IsIdle}"
                                        Background="#126DFF"
                                        Foreground="#FFFFFF"
                                        BorderThickness="0"
                                        FontWeight="SemiBold"/>

                                <Button Command="{Binding ToggleDictationCommand}"
                                        IsVisible="{Binding IsRecording}"
                                        Background="#FFF1F2"
                                        BorderBrush="#FDA4AF"
                                        BorderThickness="1"
                                        ToolTip.Tip="停止听写">
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Spacing="10">
                                        <Border Width="18"
                                                Height="18"
                                                Background="#FFE4E6"
                                                CornerRadius="9">
                                            <Border Width="8"
                                                    Height="8"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Background="#DC2626"
                                                    CornerRadius="2"/>
                                        </Border>

                                        <StackPanel Orientation="Horizontal"
                                                    Height="28"
                                                    VerticalAlignment="Center"
                                                    Spacing="3">
                                            <Border Width="3"
                                                    Height="{Binding WaveBar1Height}"
                                                    VerticalAlignment="Center"
                                                    Background="#DC2626"
                                                    CornerRadius="2"/>
                                            <Border Width="3"
                                                    Height="{Binding WaveBar2Height}"
                                                    VerticalAlignment="Center"
                                                    Background="#DC2626"
                                                    CornerRadius="2"/>
                                            <Border Width="3"
                                                    Height="{Binding WaveBar3Height}"
                                                    VerticalAlignment="Center"
                                                    Background="#DC2626"
                                                    CornerRadius="2"/>
                                            <Border Width="3"
                                                    Height="{Binding WaveBar4Height}"
                                                    VerticalAlignment="Center"
                                                    Background="#DC2626"
                                                    CornerRadius="2"/>
                                            <Border Width="3"
                                                    Height="{Binding WaveBar5Height}"
                                                    VerticalAlignment="Center"
                                                    Background="#DC2626"
                                                    CornerRadius="2"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Height="1" Background="#E3ECFA"/>

                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                        <Button Width="32"
                                Height="32"
                                Padding="0"
                                Click="OpenAccountDialog"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="#657894"
                                ToolTip.Tip="用户">
                            <Viewbox Width="18" Height="18" Stretch="Uniform">
                                <Canvas Width="1024" Height="1024">
                                    <Path Data="{StaticResource AccountIconGeometry}" Fill="#657894"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                      
                        <Button Grid.Column="3"
                                Width="32"
                                Height="32"
                                Padding="0"
                                Click="OpenSettingsDialog"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="#657894"
                                ToolTip.Tip="设置">
                            <Viewbox Width="18" Height="18" Stretch="Uniform">
                                <Canvas Width="1024" Height="1024">
                                    <Path Data="{StaticResource SettingsIconGeometry}" Fill="#657894"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                      
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Background="#FFFFFF"
                BorderThickness="0"
                CornerRadius="18,18,0,0"
                ClipToBounds="True"
                Margin="0">
            <Grid RowDefinitions="Auto,*"
                  Margin="26,20,26,0">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Spacing="10"
                            Margin="0,0,0,18">
                    <Image Source="/Assets/SayToAnyLogo.png"
                           Width="38"
                           Height="28"
                           Stretch="Uniform"/>
                    <TextBlock Text="Say To Any"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#102A56"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1">
                    <Grid>
                        <StackPanel IsVisible="{Binding IsHomeVisible}">
                     
                            <Border BorderThickness="0"
                                    CornerRadius="14"
                                    Padding="16"
                                    Background="#F8F9FB"
                                    Margin="0,0,0,24">
                                <Grid RowDefinitions="Auto,*,Auto,*">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Text="最后的转录"
                                                   FontWeight="SemiBold"
                                                   Foreground="#102A56"/>
                                        <Button Grid.Column="1"
                                                Classes="home-copy-button"
                                                Content="复制"
                                                Command="{Binding CopyFinalTextCommand}"/>
                                    </Grid>

                                    <TextBox Grid.Row="1"
                                             Classes="home-transcript-input"
                                             Text="{Binding FinalText, Mode=TwoWay}"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             MinHeight="88"
                                             Margin="0,12,0,18"
                                             PlaceholderText="识别结果会显示在这里。"/>

                                    <TextBlock Grid.Row="2"
                                               Text="原始文本"
                                               FontWeight="SemiBold"
                                               Foreground="#102A56"/>
                                    <TextBox Grid.Row="3"
                                             Classes="home-transcript-input"
                                             Text="{Binding RawTranscript, Mode=TwoWay}"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             IsReadOnly="True"
                                             MinHeight="70"
                                             Margin="0,12,0,0"
                                             PlaceholderText="原始识别文本。"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding IsHistoryVisible}">
                            <TextBlock Text="历史记录"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="#102A56"/>
                            <TextBlock Text="{Binding HistorySummaryText}"
                                       Margin="0,8,0,18"
                                       Foreground="#6E7D99"/>
                            <Border BorderThickness="0"
                                    CornerRadius="14"
                                    Padding="16"
                                    Background="#F8F9FB"
                                    Margin="0,0,0,22">
                                <StackPanel Spacing="16">
                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="18">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="保存历史"
                                                       FontWeight="SemiBold"
                                                       Foreground="#102A56"/>
                                            <TextBlock Text="您希望在设备上保存口述历史多久？"
                                                       Foreground="#6E7D99"/>
                                        </StackPanel>
                                        <ComboBox Grid.Column="1"
                                                  Width="132"
                                                  HorizontalAlignment="Right"
                                                  VerticalAlignment="Center"
                                                  ItemsSource="{Binding HistoryRetentionOptions}"
                                                  SelectedItem="{Binding SelectedHistoryRetentionOption, Mode=TwoWay}"
                                                  Background="#F7FAFF"
                                                  BorderBrush="#DCEBFF">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate DataType="vm:HistoryRetentionOption">
                                                    <TextBlock Text="{Binding DisplayName}"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </Grid>

                                    <Border Height="1"
                                            Background="#E8F0FB"/>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="隐私说明"
                                                   FontWeight="SemiBold"
                                                   Foreground="#102A56"/>
                                        <TextBlock Text="您的数据保持私密，语音口述内容是私密的。数据仅存储在您的设备上，无法从其他地方访问，也不会保存在云端。"
                                                   TextWrapping="Wrap"
                                                   Foreground="#6E7D99"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <TextBlock Text="还没有听写记录。"
                                       IsVisible="{Binding IsHistoryEmpty}"
                                       Foreground="#7B8BA6"/>
                            <ItemsControl ItemsSource="{Binding HistoryGroups}"
                                          IsVisible="{Binding HasHistory}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="models:DictationHistoryGroup">
                                        <StackPanel Margin="0,0,0,18">
                                            <Grid ColumnDefinitions="Auto,*"
                                                  ColumnSpacing="12"
                                                  Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="#526681"/>
                                                <Border Grid.Column="1"
                                                        Height="1"
                                                        VerticalAlignment="Center"
                                                        Background="#E8F0FB"/>
                                            </Grid>

                                            <ItemsControl ItemsSource="{Binding Items}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="models:DictationHistoryItem">
                                                        <Border x:Name="HistoryItemRoot"
                                                                Classes="history-record"
                                                                BorderBrush="#E5EEFA"
                                                                BorderThickness="0,0,0,1"
                                                                Padding="10,13"
                                                                Margin="0,0,0,2">
                                                            <Grid ColumnDefinitions="*,Auto"
                                                                  ColumnSpacing="14">
                                                                <StackPanel>
                                                                    <StackPanel Orientation="Horizontal"
                                                                                Spacing="8">
                                                                        <TextBlock Text="{Binding CreatedAtText}"
                                                                                   FontSize="12"
                                                                                   Foreground="#7B8BA6"/>
                                                                        <TextBlock Text="{Binding AudioStateText}"
                                                                                   FontSize="12"
                                                                                   Foreground="#7B8BA6"/>
                                                                    </StackPanel>
                                                                    <TextBlock Text="{Binding FinalText}"
                                                                               TextWrapping="Wrap"
                                                                               Margin="0,6,0,0"
                                                                               Foreground="#102A56"/>
                                                                </StackPanel>

                                                                <StackPanel Grid.Column="1"
                                                                            Classes="history-actions"
                                                                            Orientation="Horizontal"
                                                                            Spacing="6"
                                                                            VerticalAlignment="Center">
                                                                    <Button Width="32"
                                                                            Height="32"
                                                                            Classes="history-action-button"
                                                                            Padding="0"
                                                                            Click="CopyHistoryItem"
                                                                            HorizontalContentAlignment="Center"
                                                                            VerticalContentAlignment="Center"
                                                                            ToolTip.Tip="复制"
                                                                            ToolTip.Placement="Top"
                                                                            ToolTip.ShowDelay="250">
                                                                        <TextBlock Text="⧉"
                                                                                   FontSize="15"/>
                                                                    </Button>
                                                                    <Button Height="32"
                                                                            Classes="history-action-button history-menu-button"
                                                                            Padding="0"
                                                                            Click="OpenHistoryMoreMenu"
                                                                            HorizontalContentAlignment="Center"
                                                                            VerticalContentAlignment="Center"
                                                                            ToolTip.Tip="更多"
                                                                            ToolTip.Placement="Top"
                                                                            ToolTip.ShowDelay="250">
                                                                        <StackPanel Orientation="Horizontal"
                                                                                    HorizontalAlignment="Center"
                                                                                    VerticalAlignment="Center"
                                                                                    Spacing="1">
                                                                            <TextBlock Text="⋯"
                                                                                       FontSize="21"
                                                                                       Margin="0,-7,0,0"/>
                                                                        
                                                                        </StackPanel>
                                                                    </Button>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding IsSettingsVisible}">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel>
                                    <TextBlock Text="设置"
                                               FontSize="24"
                                               FontWeight="SemiBold"
                                               Foreground="#102A56"/>
                                    <TextBlock Text="OpenAI 兼容协议、麦克风和粘贴行为。"
                                               Margin="0,8,0,22"
                                               Foreground="#6E7D99"/>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="保存设置"
                                        Command="{Binding SaveSettingsCommand}"
                                        Width="104"
                                        Height="36"
                                        Background="#126DFF"
                                        Foreground="#FFFFFF"
                                        BorderThickness="0"/>
                            </Grid>

                            <Grid ColumnDefinitions="*,*"
                                  ColumnSpacing="24">
                                <Border BorderBrush="#E5EEFA"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Padding="16">
                                    <StackPanel Spacing="14">
                                        <TextBlock Text="模型服务"
                                                   FontWeight="SemiBold"
                                                   Foreground="#102A56"/>

                                        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                                              Margin="0,2,0,0">
                                            <TextBlock Text="LLM Model"
                                                       FontWeight="SemiBold"
                                                       Foreground="#102A56"/>
                                            <TextBlock Grid.Row="1" Text="Base URL" Margin="0,10,0,0"/>
                                            <TextBox Grid.Row="2"
                                                     Text="{Binding Settings.LmBaseUrl, Mode=TwoWay}"
                                                     Margin="0,6,0,0"/>
                                            <TextBlock Grid.Row="3" Text="API Key" Margin="0,10,0,0"/>
                                            <TextBox Grid.Row="4"
                                                     Text="{Binding Settings.LmApiKey, Mode=TwoWay}"
                                                     Margin="0,6,0,0"/>
                                            <TextBlock Grid.Row="5" Text="Model" Margin="0,10,0,0"/>
                                            <TextBox Grid.Row="6"
                                                     Text="{Binding Settings.LmModel, Mode=TwoWay}"
                                                     Margin="0,6,0,0"/>
                                            <Grid Grid.Row="7"
                                                  ColumnDefinitions="*,Auto"
                                                  Margin="0,12,0,0">
                                                <TextBlock Text="Temperature"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Settings.LmTemperature, StringFormat={}{0:0.0}}"
                                                           Foreground="#526681"/>
                                            </Grid>
                                            <Slider Grid.Row="8"
                                                    Minimum="0"
                                                    Maximum="2"
                                                    SmallChange="0.1"
                                                    LargeChange="0.5"
                                                    Value="{Binding Settings.LmTemperature, Mode=TwoWay}"
                                                    Margin="0,6,0,0"/>
                                        </Grid>

                                        <Border Height="1" Background="#E5EEFA"/>

                                        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                                            <TextBlock Text="ASR Model"
                                                       FontWeight="SemiBold"
                                                       Foreground="#102A56"/>
                                            <TextBlock Grid.Row="1" Text="Base URL" Margin="0,10,0,0"/>
                                            <TextBox Grid.Row="2"
                                                     Text="{Binding Settings.AsrBaseUrl, Mode=TwoWay}"
                                                     Margin="0,6,0,0"/>
                                            <TextBlock Grid.Row="3" Text="API Key" Margin="0,10,0,0"/>
                                            <TextBox Grid.Row="4"
                                                     Text="{Binding Settings.AsrApiKey, Mode=TwoWay}"
                                                     Margin="0,6,0,0"/>
                                            <TextBlock Grid.Row="5" Text="Model" Margin="0,10,0,0"/>
                                            <TextBox Grid.Row="6"
                                                     Text="{Binding Settings.AsrModel, Mode=TwoWay}"
                                                     Margin="0,6,0,0"/>
                                            <TextBlock Grid.Row="7" Text="Language" Margin="0,10,0,0"/>
                                            <StackPanel Grid.Row="8" Spacing="8" Margin="0,6,0,0">
                                                <TextBox Text="{Binding Settings.Language, Mode=TwoWay}"/>
                                                <CheckBox Content="ASR enable_itn"
                                                          IsChecked="{Binding Settings.AsrEnableItn, Mode=TwoWay}"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1"
                                        BorderBrush="#E5EEFA"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Padding="16">
                                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                                        <TextBlock Text="输入"
                                                   FontWeight="SemiBold"
                                                   Foreground="#102A56"
                                                   Margin="0,0,0,14"/>
                                        <TextBlock Grid.Row="1" Text="麦克风"/>
                                        <Grid Grid.Row="2"
                                              ColumnDefinitions="*,Auto"
                                              Margin="0,6,0,12">
                                            <Grid>
                                                <Button Command="{Binding ShowMicrophoneDialogCommand}"
                                                        Height="34"
                                                        HorizontalContentAlignment="Stretch"
                                                        Background="#F7FAFF"
                                                        BorderBrush="#DCEBFF"
                                                        BorderThickness="1"
                                                        Padding="11,0,40,0">
                                                    <TextBlock Text="{Binding SelectedMicrophoneDisplayName}"
                                                               Foreground="#102A56"
                                                               ToolTip.Tip="{Binding SelectedMicrophoneDisplayName}"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </Button>
                                                <Viewbox Width="18"
                                                         Height="18"
                                                         Stretch="Uniform"
                                                         HorizontalAlignment="Right"
                                                         VerticalAlignment="Center"
                                                         IsHitTestVisible="False"
                                                         Margin="0,0,11,0">
                                                    <Canvas Width="1024"
                                                            Height="1024">
                                                        <Path Data="{StaticResource InputDeviceMenuIconGeometry}"
                                                              Fill="#66A6EF"/>
                                                    </Canvas>
                                                </Viewbox>
                                            </Grid>
                                            <Button Grid.Column="1"
                                                    Content="刷新"
                                                    Command="{Binding RefreshMicrophonesCommand}"
                                                    Margin="8,0,0,0"/>
                                        </Grid>
                                        <TextBlock Grid.Row="3" Text="Timeout"/>
                                        <TextBox Grid.Row="4"
                                                 Text="{Binding Settings.TimeoutSeconds, Mode=TwoWay}"
                                                 Margin="0,6,0,12"/>
                                        <TextBlock Grid.Row="5" Text="最长录音秒数"/>
                                        <TextBox Grid.Row="6"
                                                 Text="{Binding Settings.MaxRecordingSeconds, Mode=TwoWay}"
                                                 Margin="0,6,0,12"/>
                                        <StackPanel Grid.Row="7" Spacing="10">
                                            <CheckBox Content="启用文本整理"
                                                      IsChecked="{Binding Settings.EnableTextCleanup, Mode=TwoWay}"/>
                                            <CheckBox Content="识别后自动粘贴"
                                                      IsChecked="{Binding Settings.AutoPasteAfterDictation, Mode=TwoWay}"/>
                                            <Button Content="测试连接"
                                                    Command="{Binding TestConnectionCommand}"
                                                    HorizontalAlignment="Left"
                                                    Width="94"
                                                    Height="34"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>
        </Grid>

        <suki:SukiDialogHost Manager="{Binding DialogManager}"/>

        <Grid IsVisible="{Binding IsMicrophoneDialogVisible}">
            <Button Command="{Binding CloseMicrophoneDialogCommand}"
                    Background="#660B1220"
                    BorderThickness="0"
                    Padding="0"/>
            <ContentControl Content="{Binding MicrophoneDialog}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</Window>
